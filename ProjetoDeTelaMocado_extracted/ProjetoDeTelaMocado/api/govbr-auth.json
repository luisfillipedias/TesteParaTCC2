    "invalid_credentials": {
      "error": "access_denied",
      "error_description": "Senha incorreta. Verifique sua senha e tente novamente."
    },
    "user_not_found": {
      "error": "invalid_request",
      "error_description": "Nenhuma conta gov.br encontrada com este CPF."
    },
    "account_inactive": {
      "error": "access_denied",
      "error_description": "Conta inativa. Entre em contato com o suporte."
    },
    "unauthorized_role": {
      "error": "insufficient_scope",
      "error_description": "Você não tem permissão para acessar este recurso."
    }
